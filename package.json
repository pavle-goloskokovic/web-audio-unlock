{
    "name": "web-audio-unlock",
    "version": "1.0.0",
    "description": "Unlocking Web Audio - the smarter way",
    "main": "dist/index.min.js",
    "module": "dist/index.min.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.min.mjs",
            "require": "./dist/index.min.js",
            "default": "./dist/index.min.mjs"
        },
        "./unminified": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "default": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup --config tsup.config.ts",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pavle-goloskokovic/web-audio-unlock.git"
    },
    "keywords": [
        "web",
        "audio",
        "webaudio",
        "unlock",
        "autoplay",
        "gesture",
        "pointer",
        "browser",
        "javascript",
        "html5",
        "typescript"
    ],
    "author": "Pavle Goloskokovic <pgoloskokovic@gmail.com> (https://prunegames.com)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/pavle-goloskokovic/web-audio-unlock/issues"
    },
    "homepage": "https://github.com/pavle-goloskokovic/web-audio-unlock#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.9.0",
        "@swc/core": "^1.15.18",
        "eslint": "^10.0.2",
        "globals": "^17.4.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
